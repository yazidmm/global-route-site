---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>

<!-- HERO -->
<section class="hero premium-hero">
  <div class="hero-content">
    <h1>Delivering Reliability, Speed, and Trust</h1>
    <p>Global Logistics Solutions Across Air, Sea, and Land</p>
    <a href="/contact" class="btn-primary">Get a Quote</a>
  </div>
</section>

<!-- SERVICES WITH IMAGES -->
<section class="image-services">

  <div class="image-grid">

    <div class="image-card">
      <img src="/images/air.jpg" alt="Air Freight" />
      <div class="overlay">
        <h3>Air Freight</h3>
      </div>
    </div>

    <div class="image-card">
      <img src="/images/sea.jpg" alt="Sea Freight" />
      <div class="overlay">
        <h3>Sea Freight</h3>
      </div>
    </div>

    <div class="image-card">
      <img src="/images/land.jpg" alt="Land Transport" />
      <div class="overlay">
        <h3>Land Transport</h3>
      </div>
    </div>

  </div>

</section>

<!-- CTA -->
<section class="cta">
  <h2>Ready to Move Your Business Forward?</h2>
  <p>Contact us today for reliable logistics solutions.</p>
  <a href="/contact" class="btn-primary">Contact Us</a>
</section>

</MainLayout>